# Production secrets for docker-compose.prod.yml.
#
# On the server: copy this to `.env` (same directory as docker-compose.prod.yml)
# and fill in real values. This file is gitignored — never commit the real one.
# It's read twice: by `docker compose` itself for ${VAR} substitution in
# docker-compose.prod.yml, and passed into the api container as its runtime env.

ENVIRONMENT=production

# Generate each with: openssl rand -hex 32
# Must differ from each other and be at least 32 characters — the app refuses
# to start in production otherwise (see backend/app/core/config.py).
SECRET_KEY=
ADMIN_SECRET_KEY=

# Postgres password (used by both the db and api services below).
POSTGRES_PASSWORD=

# Your real domain, https, no trailing slash — used for CORS and links in emails.
FRONTEND_ORIGIN=https://your-domain.example

# Keep false until TLS is actually live (DEPLOY.md step 5) — a Secure cookie
# sent over plain HTTP is silently dropped by browsers, which locks everyone
# out of /admin-tools and SQLAdmin even with correct credentials. Flip to
# true right after certbot issues the certificate.
SECURE_COOKIES=false

# First admin account — created automatically on first startup if no admin
# exists yet. Log in with this once, then manage further roles via SQLAdmin.
INITIAL_ADMIN_EMAIL=admin@your-domain.example
INITIAL_ADMIN_PASSWORD=

# Email — Yandex SMTP (see backend/.env.example for how to get an app password)
EMAIL_BACKEND=smtp
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=DАЙ ХАРD <you@yandex.ru>

# File limits (bytes) — same as dev defaults, override if needed.
MAX_IMAGE_SIZE_BYTES=10485760
MAX_TRACK_FILE_SIZE_BYTES=5242880
RESULT_DISTANCE_TOLERANCE_PCT=10
RESULT_START_TIME_TOLERANCE_MINUTES=60

# Host path the api container's media directory is bind-mounted from — the
# host nginx serves /media/* directly from this same path (see nginx/dh.conf).
MEDIA_HOST_PATH=/srv/dh/media
