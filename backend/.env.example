# App
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
DATABASE_URL=postgresql+asyncpg://dh:dh@db:5432/dh
TEST_DATABASE_URL=sqlite+aiosqlite:///./test.db

# CORS
FRONTEND_ORIGIN=http://localhost:5173

# Media storage (local volume, mounted into container)
MEDIA_ROOT=/app/media
MEDIA_URL=/media

# File limits (bytes)
MAX_IMAGE_SIZE_BYTES=10485760
MAX_TRACK_FILE_SIZE_BYTES=5242880

# Result auto-validation tolerances
RESULT_DISTANCE_TOLERANCE_PCT=10
RESULT_START_TIME_TOLERANCE_MINUTES=60

# Email — Yandex SMTP
# EMAIL_BACKEND=console -> prints emails to stdout instead of sending (dev default)
# EMAIL_BACKEND=smtp -> sends via SMTP_* settings below
#
# How to get SMTP_USERNAME / SMTP_PASSWORD:
#   1. Have a Yandex mailbox (e.g. diehardcheb@yandex.ru).
#   2. Enable two-factor auth: id.yandex.ru -> Security.
#   3. Create an app password: id.yandex.ru/security/app-passwords ->
#      "App passwords" -> type "Mail" -> copy the generated password
#      (shown once — this is SMTP_PASSWORD, NOT your account password).
#   4. SMTP_FROM must use the same address the app password was issued
#      for, or Yandex will reject/spam-filter the message.
EMAIL_BACKEND=console
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=DАЙ ХАРD <no-reply@yandex.ru>

# SQLAdmin
ADMIN_SECRET_KEY=change-me-too

# Initial admin bootstrap (created on first startup if no admin exists)
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me-admin-password
